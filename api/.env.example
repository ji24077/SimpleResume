# 이 파일은 "예시"만 담습니다. Git에 올려도 됨. 진짜 키는 넣지 마세요.
#
# 사용법:
#   cp .env.example .env
#   그다음 .env 를 열어서 OPENAI_API_KEY= 뒤에 본인 키만 넣기
#
# 실제로 읽는 파일 이름은 딱 하나:  .env  (점env)

OPENAI_API_KEY=sk-여기에_본인_키
# OPENAI_MODEL=gpt-4o-mini
# CORS_ORIGINS=http://localhost:3000

# --- PDF = Overleaf-grade (기본값, main.py와 동일) ---
# 레포 루트: docker compose build texlive
# Docker Desktop 실행 후 API 재시작. 호스트 TinyTeX는 쓰지 않음(조용한 불일치 방지).
LATEX_DOCKER_IMAGE=simpleresume-texlive:full
LATEX_DOCKER_ONLY=1
LATEX_DOCKER_NETWORK=none
# 호스트 TeX만 쓰려면(비권장): 아래 세 줄로 바꿔서 이미지 이름을 비우고 폴백 허용
# LATEX_DOCKER_IMAGE=
# LATEX_DOCKER_ONLY=0
# LATEX_DOCKER_ALLOW_FALLBACK=1
