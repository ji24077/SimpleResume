# ──────────────────────────────────────────────
# SimpleResume — root environment variable example
# ──────────────────────────────────────────────
# Copy to api/.env (for backend) and web/.env.local (for frontend).
# Git-safe: do NOT put real secrets in this file.

# ─── API (FastAPI) ───────────────────────────
OPENAI_API_KEY=sk-여기에_본인_키
# OPENAI_MODEL=gpt-4o-mini
# CORS_ORIGINS=http://localhost:3000

# Docker TeX Live for PDF compilation
LATEX_DOCKER_IMAGE=simpleresume-texlive:full
LATEX_DOCKER_NETWORK=none

# 1-page enforcement / density / ATS (see api/.env.example for full docs)
# RESUME_ONE_PAGE_MAX_REVISIONS=3
# RESUME_DENSITY_EXPAND_MAX=2
# RESUME_ATS_FIX_MAX=2
# RESUME_STRUCTURED_LATEX=true

# ─── Web (Next.js) ──────────────────────────
API_BACKEND_URL=http://127.0.0.1:8000
